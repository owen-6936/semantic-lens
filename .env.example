# Copy this file to .env and fill in your values

HOST=0.0.0.0
PORT=8000
WORKERS=1

# OCR languages — comma-separated EasyOCR language codes
# Full list: https://www.jaided.ai/easyocr/
LANGUAGES=en

# Set GPU=false to force CPU even when CUDA is available
GPU=true

# Leave empty to disable API key auth
# When set, clients must pass: X-Api-Key: <your-key>
API_KEY=

# Per-request defaults
CONFIDENCE_THRESHOLD=0.4

# Max image size accepted (bytes)
MAX_IMAGE_BYTES=10485760

# ── Stable public tunnel URLs ──────────────────────────────────────────────
# Without these set, the tunnel URL changes on every restart.

# ngrok — free static domain (one per free account)
# 1. Sign up at https://ngrok.com and grab your authtoken:
#      ngrok config add-authtoken <your-token>
# 2. Claim your free static domain at https://dashboard.ngrok.com/domains
# 3. Set it below (hostname only, no https://):
NGROK_DOMAIN=

# cloudflared — named tunnel (stable <uuid>.cfargotunnel.com URL)
# One-time setup:
#   cloudflared tunnel login
#   cloudflared tunnel create semantic-lens
# Then set the name you chose:
CF_TUNNEL=
